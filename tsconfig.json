{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017"],
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react",
    "jsxFactory": "figma.widget.h",
    "jsxFragmentFactory": "figma.widget.Fragment",
    "strict": false,
    "types": ["@figma/plugin-typings", "@figma/widget-typings"],
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": ["code.tsx"]
}
